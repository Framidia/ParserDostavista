# Dostavista API
API_BASE_URL=https://robot.dostavista.ru/api/courier/
API_VERSION=2.75
API_ENDPOINT=available-mixed-list-compact
REQUEST_REASON=auto_by_ui
TAKE_ORDER_ENDPOINT=take-order

# Required headers
DV_DEVICE_ID=your_device_id_hex_64
DV_SESSION=your_session_hex_32
USER_AGENT=ru-courier-app-main-android/2.125.0.3309
ACCEPT_ENCODING=gzip

# Filters and polling
POLL_INTERVAL_SECONDS=4
MIN_PRICE=0
MAX_DISTANCE_M=10000
HTTP_TIMEOUT_SECONDS=10
SHOW_ALL_ORDERS=false

# Courier location (for take-order)
COURIER_LATITUDE=55.06151
COURIER_LONGITUDE=82.9051117

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABCDEF
TELEGRAM_CHAT_ID=123456789

# Files
SESSION_CACHE_PATH=.session_cache
LOG_PATH=parser.log