# ==========================================
# Dostavista API Configuration
# ==========================================

# Базовый URL API Dostavista
API_BASE_URL=https://robot.dostavista.ru/api/courier/

# Версия API (обновляйте при изменениях API)
API_VERSION=2.75

# Эндпоинт для получения доступных заказов
API_ENDPOINT=available-mixed-list-compact

# Причина запроса (для логирования на стороне сервера)
REQUEST_REASON=auto_by_ui

# Эндпоинт для принятия заказа
TAKE_ORDER_ENDPOINT=take-order

# ==========================================
# Required Headers (получаются через mitmproxy)
# ==========================================

# ID устройства (64 hex-символа)
DV_DEVICE_ID=your_device_id_hex_64

# Сессионный токен (32 hex-символа)
# Если указан .session_cache, то используется он
DV_SESSION=your_session_hex_32

# User-Agent мобильного приложения
USER_AGENT=ru-courier-app-main-android/2.125.0.3309

# Заголовок сжатия
ACCEPT_ENCODING=gzip

# ==========================================
# Filters and Polling
# ==========================================

# Интервал опроса API в секундах (минимум 3)
POLL_INTERVAL_SECONDS=4

# Минимальная цена заказа (в рублях)
MIN_PRICE=0

# Максимальное расстояние до первой точки в метрах
MAX_DISTANCE_M=10000

# Таймаут HTTP-запросов в секундах
HTTP_TIMEOUT_SECONDS=10

# ==========================================
# Courier Location (для функции take-order)
# ==========================================

# Широта местоположения курьера
COURIER_LATITUDE=55.06151

# Долгота местоположения курьера
COURIER_LONGITUDE=82.9051117

# ==========================================
# Telegram Bot Configuration
# ==========================================

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABCDEF

# ID чата для отправки уведомлений (узнать через @userinfobot)
TELEGRAM_CHAT_ID=123456789

# ==========================================
# File Paths
# ==========================================

# Путь к файлу кэша сессии
SESSION_CACHE_PATH=.session_cache

# Путь к лог-файлу
LOG_PATH=parser.log
